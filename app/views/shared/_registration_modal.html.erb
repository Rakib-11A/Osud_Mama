
<!-- Login Modal-->
<div id="registration-modal" class="fixed inset-0 z-50 hidden bg-transparent bg-opacity-50 flex items-center justify-center"
     data-controller="login-modal"
     data-login-modal-target="registrationModal">
  <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
    <div class="p-6">
      <!--      Modal Header-->
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold text-gray-900">Register</h2>
        <button
          type="button"
          class="text-gray-400 hover:text-gray-600 text-xl"
          data-action="click->login-modal#close">
          ×
        </button>
      </div>

      <!--       Modal Content-->
      <div class="space-y-4">
        <%= form_with(model: User.new, url: new_user_registration_path, local: false, class: "space-y-4") do |form| %>
          <div>
            <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
            <%= form.email_field :email, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>

          <div>
            <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
            <%= form.password_field :password, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>

          <div>
            <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700" %>
            <%= form.password_field :password_confirmation, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>

          <div class="flex items-center">
            <%= form.check_box :terms_accepted, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
            <%= form.label :terms_accepted, class: "ml-2 block text-sm text-gray-900" do %>
              I agree to the <%= link_to "Terms of Service", "#", class: "text-indigo-600 hover:text-indigo-500" %> and <%= link_to "Privacy Policy", "#", class: "text-indigo-600 hover:text-indigo-500" %>
            <% end %>
          </div>

          <div class="flex gap-3">
            <%= form.submit "Register", class: "flex-1 bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
            <button
              type="button"
              class="flex-1 bg-gray-300 text-gray-700 py-2 px-4 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2"
              data-action="click->login-modal#close">
              Cancel
            </button>
          </div>
        <% end %>

        <div class="text-center pt-4 border-t">
          <p class="text-sm text-gray-600">
            Don't have an account?
            <%= link_to "Log In", "#", class: "text-indigo-600 hover:text-indigo-500 font-medium", data: {
              action: "click->login-modal#close click->login-modal#open"
            } %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>